{
  "name": "portfoliowebsite",
  "version": "2.2.1",
  "description": "Welcome to the repository for my personal portfolio site: [**charleslikesdata.com**](https://charleslikesdata.com)",
  "main": "index.html",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "lint:css": "stylelint 'src/**/*.css'",
    "lint:js": "eslint 'src/**/*.js' '__tests__/**/*.js'",
    "lint": "npm run lint:css && npm run lint:js",
    "serve": "python3 -m http.server 8000",
    "format": "prettier --write \"**/*.{html,css,js,md,json}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,md,json}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cdcoonce/Portfolio_Website.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/cdcoonce/Portfolio_Website/issues"
  },
  "homepage": "https://github.com/cdcoonce/Portfolio_Website#readme",
  "devDependencies": {
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.6.2",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "astro": "^7.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
